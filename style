body{
    background: #d4d4d4;
    padding: 10px;
    font-family: Arial, Helvetica, sans-serif;
}
.wrapper header{
    height: 500px;
    background: url(./img/builder.png);
    background-size: cover;
    background-position: center;
    padding-top: 10px;
}
.wrapper header nav a{
    text-decoration: none;
    color: #fff;
    font-size: 18px;
    padding: 0 16px;
}
.wrapper header nav a:hover{
    color: chocolate;
}
.wrapper .section{
    height: 350px;
    padding: 20px;
    background: #fff;
    margin-top: 20px;
}
.wrapper .section h1{
    margin-bottom: 10px;
    color: #606060;
}
.wrapper .section p{
    color: #808080;
    text-align: justify;
    margin-bottom: 10px;
}
.wrapper .section a{
    text-decoration: none;
    color: coral;
}
#about{
    height: 600px;
    background: #fff;
    padding: 30px;
    margin-top: 20px;
    margin-bottom: 20px;
}
#about p{
    color: #808080;
    text-align: justify;
    margin-bottom: 10px;
}
#about a{
    text-decoration: none;
    color: coral;
}
.img{
    display: flex;
    justify-content: space-between;
}
.img .img1{
    width: 32%;
    height: 250px;
    background: url("./img/builder2.jpg");
    background-size: cover;
    background-position: center;
}
.img .img2{
    width: 32%;
    height: 250px;
    background: url("./img/IMG_0134.JPG");
    background-size: cover;
    background-position: center;
}
.img .img3{
    width: 32%;
    height: 250px;
    background: url("./img/IMG_0258.JPG");
    background-size: cover;
    background-position: center;
}
#contact{
    height: 550px;
    background: #fff;
    padding: 30px;
    margin-top: 20px;
    margin-bottom: 20px;
}
#contact p{
    color: #606060;
    text-align: justify;
    margin-bottom: 20px;
}
#contact form{
    margin-top: 20px;
}
#contact form h3{
    margin-bottom: 10px;
}
#contact form input{
    width: 100%;
    padding: 10px;
    margin-bottom: 10px;
}
#contact form textarea{
    width: 100%;
    padding: 5px;
    margin-bottom: 10px;
}
#contact form button{
    padding: 12px 45px;
    background: coral;
    border: 0;
    cursor: pointer;
    color: #fff;
    font-size: 18px;
}
#contact form button:hover{
    background: green;

}
#services{
    height: 350px;
    background: #fff;
    padding: 30px;
    margin-top: 20px;
    margin-bottom: 10px;
}
#services P{
    color:#606060;
    text-align: justify;
}
#gallery .row{
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
}

/* Responsive codes */
@media screen and (max-width:600px){
    nav a{
        display: block;
        margin-bottom: 5px;
    }
    .wrapper .section{
        height: 700px;
    }
    #about{
        height: 1400px;
    }
    #about .img{
        flex-direction: column;
    }
    #about .img .img1{
        width: 100%;
        margin-bottom: 10px;
    }
    #about .img .img2{
        width: 100%;
        margin-bottom: 10px;
    }
    #about .img .img3{
        width: 100%;
        margin-bottom: 10px;
    }
    #contact{
        height: 800px;
    }
    #services{
        height: 850px;
    }
    #gallery .row{
        flex-direction: column;
    }
    #gallery .row .gal{
        width: 100%;
        margin-bottom: 10px;
    }
    
    
}